#!/usr/bin/env bash
#MISE description="Migrate mise run calls to _task pattern"
#USAGE arg "<target>" help="Path to the codebase to migrate"

set -euo pipefail

TARGET="${usage_target}"

if [[ ! -e "$TARGET" ]]; then
  echo "ERROR: target does not exist: $TARGET" >&2
  exit 1
fi

# Find bash task files
find_bash_tasks() {
  local target="$1"

  # Files with .sh/.bash extension
  find "$target" -type f \( -name "*.sh" -o -name "*.bash" \) 2>/dev/null

  # Extension-less files with bash shebang
  find "$target" -type f ! -name "*.*" 2>/dev/null | while read -r f; do
    if head -1 "$f" 2>/dev/null | grep -q '#!/usr/bin/env bash\|#!/bin/bash'; then
      echo "$f"
    fi
  done
}

# Migrate a single file in-place
migrate_file() {
  local file="$1"

  # Replace `mise run -q <task>` with `_task <task>` (strip -q)
  # Replace `mise run <task>` with `_task <task>`
  #
  # Only match lines where mise run is an actual command invocation,
  # not inside strings (echo, printf) or comments.
  #
  # Strategy: process line by line, only transform lines where
  # `mise run` appears as a command (not inside quotes or after echo/printf).

  local tmp="${file}.migrate.tmp"

  while IFS= read -r line; do
    # Skip comment lines
    if [[ "$line" =~ ^[[:space:]]*# ]]; then
      echo "$line"
      continue
    fi

    # Skip lines where mise run is in a non-executable context:
    # 1. ${var:?error message} bash error strings
    if echo "$line" | grep -qE '\$\{[^}]*:\?.*mise run'; then
      echo "$line"
      continue
    fi
    # 2. echo/printf lines where mise run is NOT inside a live $() substitution
    #    Heuristic: if the line starts with echo/printf AND contains \$( (escaped),
    #    or mise run appears without a preceding unescaped $(, it's a string.
    if echo "$line" | grep -qE '(echo|printf)[[:space:]]'; then
      # Check if mise run appears after an unescaped $( — that's a live substitution
      if echo "$line" | grep -qE '[^\\]\$\(.*mise run' && \
         ! echo "$line" | grep -qE '\\\$\(.*mise run'; then
        # Live $() inside echo — migrate the mise run calls
        :  # fall through to replacement
      else
        echo "$line"
        continue
      fi
    fi

    # Replace mise run -q <task> → _task <task>
    line=$(echo "$line" | sed -E 's/mise run -q ([^ )]+)/_task \1/g')

    # Replace mise run <task> → _task <task>
    # Only match task names (word:word pattern or plain word, not flags starting with -)
    line=$(echo "$line" | sed -E 's/mise run ([a-zA-Z_][a-zA-Z0-9_:.-]*)/_task \1/g')

    echo "$line"
  done < "$file" > "$tmp"

  mv "$tmp" "$file"
}

# Process all bash task files
while IFS= read -r file; do
  migrate_file "$file"
done < <(find_bash_tasks "$TARGET")
