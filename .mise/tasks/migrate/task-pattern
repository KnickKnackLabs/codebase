#!/usr/bin/env bash
#MISE description="Migrate mise run calls to _task pattern (or reverse)"
#USAGE arg "<target>" help="Path to the codebase to migrate"
#USAGE flag "--reverse" help="Reverse: _task back to mise run"

set -euo pipefail

# shellcheck source=../../../lib/shell-files.sh
source "$MISE_CONFIG_ROOT/lib/shell-files.sh"

TARGET=$(resolve_target "${usage_target}")
REVERSE="${usage_reverse:-false}"

if [[ ! -e "$TARGET" ]]; then
  echo "ERROR: target does not exist: $TARGET" >&2
  exit 1
fi

# Find bash task files
find_bash_tasks() {
  local target="$1"

  # Files with .sh/.bash extension
  find "$target" -type f \( -name "*.sh" -o -name "*.bash" \) 2>/dev/null

  # Extension-less files with bash shebang
  find "$target" -type f ! -name "*.*" 2>/dev/null | while read -r f; do
    if head -1 "$f" 2>/dev/null | grep -q '#!/usr/bin/env bash\|#!/bin/bash'; then
      echo "$f"
    fi
  done
}

# Migrate a single file in-place (forward or reverse)
migrate_file() {
  local file="$1"
  local tmp="${file}.migrate.tmp"

  # Strategy: process line by line, only transform lines where
  # the pattern appears as a command (not inside quotes or after echo/printf).

  while IFS= read -r line; do
    # Skip comment lines
    if [[ "$line" =~ ^[[:space:]]*# ]]; then
      echo "$line"
      continue
    fi

    if [[ "$REVERSE" == "true" ]]; then
      # --- Reverse: _task → mise run ---

      # Skip lines where _task appears in non-executable context
      if echo "$line" | grep -qE '(echo|printf)[[:space:]]'; then
        if echo "$line" | grep -qE '[^\\]\$\(.*_task' && \
           ! echo "$line" | grep -qE '\\\$\(.*_task'; then
          :  # live $() — fall through
        else
          echo "$line"
          continue
        fi
      fi

      # Replace _task <name> → mise run <name>
      line=$(echo "$line" | sed -E 's/_task ([a-zA-Z_][a-zA-Z0-9_:.-]*)/mise run \1/g')
    else
      # --- Forward: mise run → _task ---

      # Skip lines where mise run is in a non-executable context:
      # 1. ${var:?error message} bash error strings
      if echo "$line" | grep -qE '\$\{[^}]*:\?.*mise run'; then
        echo "$line"
        continue
      fi
      # 2. echo/printf lines where mise run is NOT inside a live $() substitution
      if echo "$line" | grep -qE '(echo|printf)[[:space:]]'; then
        if echo "$line" | grep -qE '[^\\]\$\(.*mise run' && \
           ! echo "$line" | grep -qE '\\\$\(.*mise run'; then
          :  # live $() — fall through
        else
          echo "$line"
          continue
        fi
      fi

      # Replace mise run -q <task> → _task <task>
      line=$(echo "$line" | sed -E 's/mise run -q ([^ )]+)/_task \1/g')

      # Replace mise run <task> → _task <task>
      line=$(echo "$line" | sed -E 's/mise run ([a-zA-Z_][a-zA-Z0-9_:.-]*)/_task \1/g')
    fi

    echo "$line"
  done < "$file" > "$tmp"

  mv "$tmp" "$file"
}

# Process all bash task files
while IFS= read -r file; do
  migrate_file "$file"
done < <(find_bash_tasks "$TARGET")
