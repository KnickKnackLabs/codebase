#!/usr/bin/env bash
#MISE description="Scan codebases for AST pattern matches"
#USAGE arg "<targets>…" help="Paths to codebases to scan (one or more)"
#USAGE flag "-p --pattern <pattern>" required=#true help="ast-grep pattern to search for"
#USAGE flag "-l --lang <lang>" help="Language (default: bash)"
#USAGE flag "-e --exclude <excludes>" help="Glob patterns to exclude (space-separated)"

set -euo pipefail

# shellcheck source=../../lib/shell-files.sh
source "$MISE_CONFIG_ROOT/lib/shell-files.sh"

PATTERN="${usage_pattern}"
LANG="${usage_lang:-bash}"
# Note: the USAGE flag name is '--exclude', so mise exports 'usage_exclude'.
# The arg-name '<excludes>' in the USAGE spec is only used in help text.
EXCLUDES="${usage_exclude:-}"

if [[ -z "$PATTERN" ]]; then
  echo "ERROR: --pattern is required" >&2
  exit 1
fi

# Collect targets from positional args
IFS=' ' read -ra TARGETS <<< "${usage_targets}"

if [[ ${#TARGETS[@]} -eq 0 ]]; then
  echo "ERROR: at least one target is required" >&2
  exit 1
fi

# Resolve relative paths against CALLER_PWD (see lib/shell-files.sh).
for i in "${!TARGETS[@]}"; do
  TARGETS[$i]=$(resolve_target "${TARGETS[$i]}")
done

# Validate all targets exist
for target in "${TARGETS[@]}"; do
  if [[ ! -e "$target" ]]; then
    echo "ERROR: target does not exist: $target" >&2
    exit 1
  fi
done

# Scan a single target, output with target prefix for multi-target runs
scan_target() {
  local target="$1"
  local prefix="$2"

  local work_dir
  work_dir=$(mktemp -d)

  local file_count=0
  while IFS= read -r src; do
    rel="${src#"$target"/}"

    # Check excludes
    if [[ -n "$EXCLUDES" ]]; then
      skip=false
      for glob in $EXCLUDES; do
        # shellcheck disable=SC2254
        case "$rel" in $glob) skip=true; break ;; esac
      done
      $skip && continue
    fi

    dest="$work_dir/$rel.sh"
    mkdir -p "$(dirname "$dest")"
    cp "$src" "$dest"
    file_count=$((file_count + 1))
  done < <(discover_shell_files "$target")

  if [[ "$file_count" -eq 0 ]]; then
    rm -rf "$work_dir"
    return
  fi

  # sg exits non-zero on no matches; treat empty output as "nothing found".
  if ! raw_output=$(sg run --pattern "$PATTERN" -l "$LANG" --no-ignore hidden "$work_dir" 2>/dev/null); then
    raw_output=""
  fi
  rm -rf "$work_dir"

  if [[ -z "$raw_output" ]]; then
    return
  fi

  # Rewrite paths: strip work dir prefix and .sh suffix, add target prefix
  if [[ -n "$prefix" ]]; then
    echo "$raw_output" | sed "s|$work_dir/||g" | sed 's|\.sh:|:|g; s|\.sh$||g' | sed "s|^|$prefix:|"
  else
    echo "$raw_output" | sed "s|$work_dir/||g" | sed 's|\.sh:|:|g; s|\.sh$||g'
  fi
}

# Run scan on each target
multi=$([[ ${#TARGETS[@]} -gt 1 ]] && echo true || echo false)

for target in "${TARGETS[@]}"; do
  if [[ "$multi" == "true" ]]; then
    name=$(basename "$target")
    scan_target "$target" "$name"
  else
    scan_target "$target" ""
  fi
done
