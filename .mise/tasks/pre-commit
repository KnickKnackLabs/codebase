#!/usr/bin/env bash
#MISE description="Install or check codebase pre-commit hook"
#USAGE flag "--revert" help="Remove the codebase pre-commit hook"
#USAGE flag "--check" help="Check if hook is installed and current (no changes)"

set -euo pipefail

REVERT="${usage_revert:-false}"
CHECK="${usage_check:-false}"

# Find repo root from current directory
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || true)
if [[ -z "$REPO_ROOT" ]]; then
  echo "ERROR: not in a git repository" >&2
  exit 1
fi

TOML="$REPO_ROOT/mise.toml"
HOOK="$REPO_ROOT/.git/hooks/pre-commit"
HOOK_DIR="$REPO_ROOT/.git/hooks/pre-commit.d"
CODEBASE_HOOK="$HOOK_DIR/codebase"

# --- Revert ---
if [[ "$REVERT" == "true" ]]; then
  if [[ ! -f "$CODEBASE_HOOK" ]]; then
    echo "No codebase hook installed"
    exit 0
  fi

  rm "$CODEBASE_HOOK"
  echo "Removed codebase hook"

  # Clean up empty dispatcher
  if [[ -d "$HOOK_DIR" ]] && [[ -z "$(ls -A "$HOOK_DIR")" ]]; then
    rmdir "$HOOK_DIR"
    if [[ -f "$HOOK" ]] && grep -q "pre-commit.d" "$HOOK"; then
      rm "$HOOK"
      echo "Removed empty pre-commit dispatcher"
    fi
  fi
  exit 0
fi

# --- Read config ---
if [[ ! -f "$TOML" ]]; then
  echo "ERROR: no mise.toml found" >&2
  exit 1
fi

RULES=$(awk '
  /^\[_\.codebase\]/ { in_section=1; next }
  /^\[/ { in_section=0 }
  in_section && /^lint[ \t]*=/ {
    gsub(/.*=[ \t]*\[/, "")
    gsub(/\].*/, "")
    gsub(/"/, "")
    gsub(/,/, " ")
    gsub(/^[ \t]+|[ \t]+$/, "")
    print
  }
' "$TOML")

if [[ -z "$RULES" ]]; then
  if [[ "$CHECK" == "true" ]]; then
    exit 1
  fi
  echo "ERROR: no lint rules configured in $TOML" >&2
  echo "Add to mise.toml:" >&2
  echo '  [_.codebase]' >&2
  echo '  lint = ["mise-settings", "gum-table"]' >&2
  exit 1
fi

# Read per-rule scope overrides from [_.codebase.scope]
declare -A SCOPES
while IFS='=' read -r rule scope; do
  [[ -z "$rule" ]] && continue
  rule=$(echo "$rule" | tr -d ' "')
  scope=$(echo "$scope" | tr -d ' "')
  SCOPES["$rule"]="$scope"
done < <(awk '
  /^\[_\.codebase\.scope\]/ { in_section=1; next }
  /^\[/ { in_section=0 }
  in_section && /=/ { print }
' "$TOML")

# Default scopes per rule
declare -A DEFAULT_SCOPES
DEFAULT_SCOPES[mise-settings]="."
DEFAULT_SCOPES[gum-table]=".mise/tasks"

resolve_scope() {
  local rule="$1"
  if [[ -n "${SCOPES[$rule]:-}" ]]; then
    echo "${SCOPES[$rule]}"
  elif [[ -n "${DEFAULT_SCOPES[$rule]:-}" ]]; then
    echo "${DEFAULT_SCOPES[$rule]}"
  else
    echo "."
  fi
}

# --- Build scope map ---
SCOPE_ENTRIES=""
for rule in $RULES; do
  scope=$(resolve_scope "$rule")
  SCOPE_ENTRIES+="SCOPES[\"$rule\"]=\"$scope\""$'\n'
done

# --- Generate hook content ---
NEW_HOOK=$(cat <<HOOK
#!/usr/bin/env bash
# Auto-generated by: codebase pre-commit
# Runs codebase lint rules configured in mise.toml [_.codebase].lint
set -eo pipefail

REPO_ROOT="\$(git rev-parse --show-toplevel)"

RULES=($RULES)

declare -A SCOPES
$SCOPE_ENTRIES

failures=0

for rule in "\${RULES[@]}"; do
  scope="\${SCOPES[\$rule]:-.}"
  target="\$REPO_ROOT/\$scope"

  [[ "\$scope" == "." ]] && target="\$REPO_ROOT"

  output=\$(codebase lint:"\$rule" "\$target" 2>&1) || status=\$?
  if [ "\${status:-0}" -ne 0 ]; then
    echo "codebase: lint:\$rule failed" >&2
    echo "\$output" | grep -v '^INFO' | grep -v '^OK' | grep -v '\[lint:' >&2 || true
    failures=\$((failures + 1))
  fi
done

if [ "\$failures" -gt 0 ]; then
  echo "" >&2
  echo "codebase: \$failures lint rule(s) failed. Fix issues or commit with --no-verify." >&2
  exit 1
fi
HOOK
)

# --- Check mode ---
if [[ "$CHECK" == "true" ]]; then
  if [[ -f "$CODEBASE_HOOK" ]] && [[ "$(cat "$CODEBASE_HOOK")" == "$NEW_HOOK" ]]; then
    exit 0
  else
    exit 1
  fi
fi

# --- Install dispatcher if missing ---
if [[ -f "$HOOK" ]] && ! grep -q "pre-commit.d" "$HOOK"; then
  echo "ERROR: existing pre-commit hook is not a dispatcher" >&2
  echo "Move it to .git/hooks/pre-commit.d/ manually, then re-run." >&2
  exit 1
fi

if [[ ! -f "$HOOK" ]]; then
  mkdir -p "$HOOK_DIR"
  cat > "$HOOK" <<'DISPATCHER'
#!/usr/bin/env bash
# Pre-commit dispatcher — runs all executable scripts in pre-commit.d/
set -eo pipefail
HOOK_DIR="$(dirname "$0")/pre-commit.d"
for hook in "$HOOK_DIR"/*; do
  [ -x "$hook" ] && "$hook" || exit $?
done
DISPATCHER
  chmod +x "$HOOK"
else
  mkdir -p "$HOOK_DIR"
fi

# --- Write if changed ---
if [[ -f "$CODEBASE_HOOK" ]] && [[ "$(cat "$CODEBASE_HOOK")" == "$NEW_HOOK" ]]; then
  echo "pre-commit hook up to date"
else
  echo "$NEW_HOOK" > "$CODEBASE_HOOK"
  chmod +x "$CODEBASE_HOOK"
  echo "Installed pre-commit hook"
fi
