#!/usr/bin/env bash
#MISE description="Install codebase lint pre-commit hook"
#USAGE arg "<target>" help="Path to the codebase to install hook in"

set -euo pipefail

TARGET="${usage_target}"

if [[ ! -d "$TARGET/.git" ]]; then
  echo "ERROR: $TARGET is not a git repository" >&2
  exit 1
fi

TOML="$TARGET/mise.toml"
if [[ ! -f "$TOML" ]]; then
  echo "ERROR: no mise.toml found in $TARGET" >&2
  exit 1
fi

# Read lint rules from [_.codebase].lint
RULES=$(awk '
  /^\[_\.codebase\]/ { in_section=1; next }
  /^\[/ { in_section=0 }
  in_section && /^lint[ \t]*=/ {
    gsub(/.*=[ \t]*\[/, "")
    gsub(/\].*/, "")
    gsub(/"/, "")
    gsub(/,/, " ")
    gsub(/^[ \t]+|[ \t]+$/, "")
    print
  }
' "$TOML")

if [[ -z "$RULES" ]]; then
  echo "ERROR: no lint rules configured in $TOML" >&2
  echo "Add to mise.toml:" >&2
  echo '  [_.codebase]' >&2
  echo '  lint = ["mise-settings", "gum-table"]' >&2
  exit 1
fi

# Read per-rule scope overrides from [_.codebase.scope]
# e.g. gum-table = ".mise/tasks"
declare -A SCOPES
while IFS='=' read -r rule scope; do
  [[ -z "$rule" ]] && continue
  rule=$(echo "$rule" | tr -d ' "')
  scope=$(echo "$scope" | tr -d ' "')
  SCOPES["$rule"]="$scope"
done < <(awk '
  /^\[_\.codebase\.scope\]/ { in_section=1; next }
  /^\[/ { in_section=0 }
  in_section && /=/ { print }
' "$TOML")

# Default scopes per rule
declare -A DEFAULT_SCOPES
DEFAULT_SCOPES[mise-settings]="."
DEFAULT_SCOPES[gum-table]=".mise/tasks"

# Resolve scope: explicit > default > "."
resolve_scope() {
  local rule="$1"
  if [[ -n "${SCOPES[$rule]:-}" ]]; then
    echo "${SCOPES[$rule]}"
  elif [[ -n "${DEFAULT_SCOPES[$rule]:-}" ]]; then
    echo "${DEFAULT_SCOPES[$rule]}"
  else
    echo "."
  fi
}

echo "Rules:"
for rule in $RULES; do
  scope=$(resolve_scope "$rule")
  echo "  $rule → $scope"
done

# --- Install dispatcher if missing ---
HOOK="$TARGET/.git/hooks/pre-commit"
HOOK_DIR="$TARGET/.git/hooks/pre-commit.d"

if [[ -f "$HOOK" ]] && ! grep -q "pre-commit.d" "$HOOK"; then
  echo "ERROR: existing pre-commit hook is not a dispatcher" >&2
  echo "Move it to .git/hooks/pre-commit.d/ manually, then re-run." >&2
  exit 1
fi

if [[ ! -f "$HOOK" ]]; then
  mkdir -p "$HOOK_DIR"
  cat > "$HOOK" <<'DISPATCHER'
#!/usr/bin/env bash
# Pre-commit dispatcher — runs all executable scripts in pre-commit.d/
set -eo pipefail
HOOK_DIR="$(dirname "$0")/pre-commit.d"
for hook in "$HOOK_DIR"/*; do
  [ -x "$hook" ] && "$hook" || exit $?
done
DISPATCHER
  chmod +x "$HOOK"
  echo "Installed pre-commit dispatcher"
else
  mkdir -p "$HOOK_DIR"
fi

# --- Build scope map for the hook ---
SCOPE_ENTRIES=""
for rule in $RULES; do
  scope=$(resolve_scope "$rule")
  SCOPE_ENTRIES+="SCOPES[\"$rule\"]=\"$scope\""$'\n'
done

# --- Write codebase hook ---
CODEBASE_HOOK="$HOOK_DIR/codebase"
cat > "$CODEBASE_HOOK" <<HOOK
#!/usr/bin/env bash
# Auto-generated by: codebase pre-commit install
# Runs codebase lint rules configured in mise.toml [_.codebase].lint
set -eo pipefail

REPO_ROOT="\$(git rev-parse --show-toplevel)"

RULES=($RULES)

declare -A SCOPES
$SCOPE_ENTRIES

failures=0

for rule in "\${RULES[@]}"; do
  scope="\${SCOPES[\$rule]:-.}"
  target="\$REPO_ROOT/\$scope"

  # Normalize: if scope is ".", just use REPO_ROOT
  [[ "\$scope" == "." ]] && target="\$REPO_ROOT"

  output=\$(codebase lint:"\$rule" "\$target" 2>&1)
  status=\$?
  if [ "\$status" -ne 0 ]; then
    # Only show WARN/FAIL/ERROR lines, not INFO
    echo "\$output" | grep -E '^(WARN|FAIL|ERROR)' >&2
    failures=\$((failures + 1))
  fi
done

if [ "\$failures" -gt 0 ]; then
  echo "" >&2
  echo "codebase: \$failures lint rule(s) failed. Fix issues or commit with --no-verify." >&2
  exit 1
fi
HOOK
chmod +x "$CODEBASE_HOOK"

echo "Installed codebase hook → .git/hooks/pre-commit.d/codebase"
