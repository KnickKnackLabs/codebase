#!/usr/bin/env bash
#MISE description="Remove codebase lint pre-commit hook"
#USAGE arg "<target>" help="Path to the codebase to remove hook from"

set -euo pipefail

TARGET="${usage_target}"

if [[ ! -d "$TARGET/.git" ]]; then
  echo "ERROR: $TARGET is not a git repository" >&2
  exit 1
fi

CODEBASE_HOOK="$TARGET/.git/hooks/pre-commit.d/codebase"

if [[ ! -f "$CODEBASE_HOOK" ]]; then
  echo "No codebase hook installed in $TARGET"
  exit 0
fi

rm "$CODEBASE_HOOK"
echo "Removed codebase hook from .git/hooks/pre-commit.d/"

# Clean up empty pre-commit.d directory
HOOK_DIR="$TARGET/.git/hooks/pre-commit.d"
if [[ -d "$HOOK_DIR" ]] && [[ -z "$(ls -A "$HOOK_DIR")" ]]; then
  rmdir "$HOOK_DIR"
  # Remove dispatcher too if it's ours and nothing else uses it
  HOOK="$TARGET/.git/hooks/pre-commit"
  if [[ -f "$HOOK" ]] && grep -q "pre-commit.d" "$HOOK"; then
    rm "$HOOK"
    echo "Removed empty pre-commit dispatcher"
  fi
fi
