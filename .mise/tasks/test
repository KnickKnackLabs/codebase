#!/usr/bin/env bash
#MISE description="Run BATS test suite"
#USAGE arg "[args]..." var=#true help="Test suites, files, or bats flags"
#USAGE example "mise run test" header="Run all tests"
#USAGE example "mise run test lint/bats-test-task" header="Run a specific suite by path"
#USAGE example "mise run test test/lint/or-true/or-true.bats" header="Run a specific file"
#USAGE example "mise run test -- --filter rejects" header="Filter tests by name"
set -eo pipefail

TEST_DIR="$MISE_CONFIG_ROOT/test"

args=()
has_target=false

for arg in "$@"; do
  if [[ "$arg" != -* && "$arg" != *.bats && -d "$TEST_DIR/$arg" ]]; then
    args+=("$TEST_DIR/$arg")
    has_target=true
  else
    [[ "$arg" == *.bats || -d "$arg" ]] && has_target=true
    args+=("$arg")
  fi
done

if ! $has_target; then
  # Enumerate real test files explicitly — the lint-rule fixtures under
  # test/lint/*/fixtures/ contain synthetic .bats files (intentionally bad
  # inputs for the rules), and bats' --recursive walk would otherwise try
  # to execute them. fd's '--exclude fixtures' is path-component-aware,
  # so it skips only nested 'fixtures/' dirs. This is a standard codebase-
  # self-hosting wrinkle — other repos can use the simpler
  # `args+=("--recursive" "$TEST_DIR/")` from the canonical.
  while IFS= read -r f; do
    args+=("$f")
  done < <(fd -t f -e bats --exclude fixtures . "$TEST_DIR" | sort)
fi

bats "${args[@]}"
