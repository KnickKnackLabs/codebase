#!/usr/bin/env bash
#MISE description="Detect manual table formatting that should use gum table"
#USAGE arg "<targets>…" help="Paths to codebases to check (one or more)"

set -euo pipefail

# shellcheck source=../../../lib/shell-files.sh
source "$MISE_CONFIG_ROOT/lib/shell-files.sh"

IFS=' ' read -ra TARGETS <<< "${usage_targets}"

if [[ ${#TARGETS[@]} -eq 0 ]]; then
  echo "ERROR: at least one target is required" >&2
  exit 1
fi

# Scan a single file. Single-pass: track loop depth as we go,
# classify hits inline. Emits hits on stdout, one per line.
# (Bash 3 compatible — no namerefs.)
scan_file() {
  local file="$1"
  local loop_depth=0
  local lineno=0
  local line

  while IFS= read -r line; do
    lineno=$((lineno + 1))

    # Track loop depth (while/for ... done)
    if [[ "$line" =~ (^|[\;\&\|])[[:space:]]*(while|for)[[:space:]] ]]; then
      loop_depth=$((loop_depth + 1))
    fi
    if [[ "$line" =~ (^|[\;])[[:space:]]*done([[:space:]]|$) ]]; then
      loop_depth=$((loop_depth - 1))
    fi

    # Skip comment lines
    [[ "$line" =~ ^[[:space:]]*\# ]] && continue

    # Skip inline ignore
    [[ "$line" == *"codebase:ignore"* ]] && continue

    # Skip error strings
    # shellcheck disable=SC2016  # intentional: match literal '${' as a pattern
    [[ "$line" == *'${'*':?'*'%-'* ]] && continue

    # Skip echo'd usage instructions
    [[ "$line" =~ ^[[:space:]]*(echo|Echo)[[:space:]].*%-[0-9]+ ]] && continue

    # Pattern: column -t
    if [[ "$line" == *'| column -t'* ]] || [[ "$line" == *'|column -t'* ]]; then
      echo "[column-t] $lineno: $line"
      continue
    fi

    # Pattern: printf with %-Ns
    if [[ "$line" == *'printf'*'%-'*'s'* ]]; then
      if [[ $loop_depth -gt 0 ]]; then
        echo "[loop-table] $lineno: $line"
      else
        echo "[padding] $lineno: $line"
      fi
    fi

  done < "$file"
}

failures=0

for target in "${TARGETS[@]}"; do
  if [[ ! -e "$target" ]]; then
    echo "ERROR: target does not exist: $target" >&2
    exit 1
  fi

  while IFS= read -r file; do
    rel="${file#"$target"/}"
    hits=()

    while IFS= read -r _hit; do
      [[ -n "$_hit" ]] && hits+=("$_hit")
    done < <(scan_file "$file")

    if [[ ${#hits[@]} -gt 0 ]]; then
      # Check if file already uses gum table (suppress if so)
      if grep -q 'gum table' "$file"; then
        continue
      fi

      name=$(basename "$target")
      has_high_confidence=false
      for hit in "${hits[@]}"; do
        if [[ "$hit" == "[column-t]"* ]] || [[ "$hit" == "[loop-table]"* ]]; then
          echo "WARN  $name:$rel:$hit"
          has_high_confidence=true
        else
          echo "INFO  $name:$rel:$hit"
        fi
      done
      if $has_high_confidence; then
        failures=$((failures + 1))
      fi
    fi
  done < <(discover_shell_files "$target")
done

if [[ "$failures" -eq 0 ]]; then
  echo "OK    no manual table formatting found"
fi

exit "$failures"
