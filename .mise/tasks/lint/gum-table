#!/usr/bin/env bash
#MISE description="Detect manual table formatting that should use gum table"
#USAGE arg "<targets>…" help="Paths to codebases to check (one or more)"

set -euo pipefail

IFS=' ' read -ra TARGETS <<< "${usage_targets}"

if [[ ${#TARGETS[@]} -eq 0 ]]; then
  echo "ERROR: at least one target is required" >&2
  exit 1
fi

# Find bash task files
find_bash_tasks() {
  local target="$1"
  find "$target" -type f \( -name "*.sh" -o -name "*.bash" \) 2>/dev/null
  find "$target" -type f ! -name "*.*" 2>/dev/null | while read -r f; do
    if head -1 "$f" 2>/dev/null | grep -q '#!/usr/bin/env bash\|#!/bin/bash'; then
      echo "$f"
    fi
  done
}

# Classify a printf-padding hit by checking if it's inside a loop.
# Reads the file up to the given line number, looking for enclosing
# while/for that hasn't been closed by done.
is_inside_loop() {
  local file="$1"
  local target_line="$2"
  local depth=0
  local n=0
  while IFS= read -r line; do
    n=$((n + 1))
    [ "$n" -ge "$target_line" ] && break
    # Count loop openers (while/for at start of line or after ; / &&/ ||)
    if echo "$line" | grep -qE '(^|;|&&|\|\||\|)[[:space:]]*(while|for)\b'; then
      depth=$((depth + 1))
    fi
    # Count loop closers
    if echo "$line" | grep -qE '(^|;)[[:space:]]*done\b'; then
      depth=$((depth - 1))
    fi
  done < "$file"
  [ "$depth" -gt 0 ]
}

failures=0

for target in "${TARGETS[@]}"; do
  if [[ ! -e "$target" ]]; then
    echo "ERROR: target does not exist: $target" >&2
    exit 1
  fi

  while IFS= read -r file; do
    rel="${file#"$target"/}"
    hits=()

    lineno=0
    while IFS= read -r line; do
      lineno=$((lineno + 1))

      # Skip comment lines
      [[ "$line" =~ ^[[:space:]]*# ]] && continue

      # Skip lines with inline ignore marker
      [[ "$line" == *"codebase:ignore"* ]] && continue

      # Skip lines where the pattern is inside a :? error string
      echo "$line" | grep -qE '\$\{[^}]*:\?.*%-[0-9]' && continue

      # Skip echo/printf lines that are displaying usage instructions
      if echo "$line" | grep -qE '^[[:space:]]*(echo|Echo) ".*%-[0-9]+'; then
        continue
      fi

      # Pattern: piping to column -t (always high confidence)
      if echo "$line" | grep -qE '\|\s*column\s+-t'; then
        hits+=("[column-t] $lineno: $line")
        continue
      fi

      # Pattern: printf with fixed-width padding (%-Ns)
      if echo "$line" | grep -qE 'printf.*%-[0-9]+s'; then
        if is_inside_loop "$file" "$lineno"; then
          hits+=("[loop-table] $lineno: $line")
        else
          hits+=("[padding] $lineno: $line")
        fi
      fi

    done < "$file"

    if [[ ${#hits[@]} -gt 0 ]]; then
      # Check if file already uses gum table (suppress if so)
      if grep -q 'gum table' "$file"; then
        continue
      fi

      name=$(basename "$target")
      has_high_confidence=false
      for hit in "${hits[@]}"; do
        if [[ "$hit" == "[column-t]"* ]] || [[ "$hit" == "[loop-table]"* ]]; then
          echo "WARN  $name:$rel:$hit"
          has_high_confidence=true
        else
          echo "INFO  $name:$rel:$hit"
        fi
      done
      if $has_high_confidence; then
        failures=$((failures + 1))
      fi
    fi
  done < <(find_bash_tasks "$target")
done

if [[ "$failures" -eq 0 ]]; then
  echo "OK    no manual table formatting found"
fi

exit "$failures"
