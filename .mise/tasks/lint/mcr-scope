#!/usr/bin/env bash
#MISE description="Forbid MISE_CONFIG_ROOT in test/ and lib/ (use BATS_TEST_DIRNAME or BASH_SOURCE instead)"
#USAGE arg "<targets>…" help="Paths to codebases to check (one or more)"

set -euo pipefail

# shellcheck source=../../../lib/shell-files.sh
source "$MISE_CONFIG_ROOT/lib/shell-files.sh"

# Rationale: $MISE_CONFIG_ROOT is a *task-execution* primitive. In test
# helpers and library files it's unreliable — agent sessions are
# themselves spawned from a mise task (e.g. `shimmer agent`), so MCR is
# already set to the launcher's repo and persists. A direct
# `bats test/foo.bats` or `source lib/foo.sh` inherits that wrong value.
#
# Context-appropriate primitives:
#
#   .mise/tasks/*  →  $MISE_CONFIG_ROOT     (mise dispatched the task; safe)
#   lib/*.sh       →  "${BASH_SOURCE[0]}"   (self-locating)
#   test/*         →  $BATS_TEST_DIRNAME    (bats sets this from the file path)
#
# Legitimate exceptions can opt out with an inline `# codebase:ignore`
# comment or a whole-file opt-out via `codebase:ignore mcr-scope` in the
# target's mise.toml. None are known in our codebases at the time this
# rule was written.
#
# See: fold/notes/mise-gotchas.md ("$MISE_CONFIG_ROOT persists across
# tool boundaries in agent sessions") and den/notes/
# three-primitives-three-contexts.md for the mechanism.

IFS=' ' read -ra TARGETS <<< "${usage_targets}"

if [[ ${#TARGETS[@]} -eq 0 ]]; then
  echo "ERROR: at least one target is required" >&2
  exit 1
fi

# Resolve relative paths against CALLER_PWD (see lib/shell-files.sh).
for i in "${!TARGETS[@]}"; do
  TARGETS[$i]=$(resolve_target "${TARGETS[$i]}")
done

# Patterns — checked independently so we can name the shape in output.
#
#   $MISE_CONFIG_ROOT           — bare form
#   ${MISE_CONFIG_ROOT}         — brace form: covers ${MCR}, ${MCR:-default},
#                                ${MCR:+alt}, ${MCR%/...}, ${MCR#...},
#                                ${MCR/old/new}, and bare ${MCR} itself.
#
# Terminator after the name uses [^A-Za-z0-9_] to reject speculative vars
# like $MISE_CONFIG_ROOT_FOO while matching any bash parameter-expansion
# operator (`}`, `:`, `%`, `#`, `/`, `+`, `?`, `-`, etc.) in one shot.
BARE_RE='\$MISE_CONFIG_ROOT([^A-Za-z0-9_]|$)'
BRACE_RE='\$\{MISE_CONFIG_ROOT[^A-Za-z0-9_]'

# discover_test_lib_files <target>
#
# Emit paths of files where $MISE_CONFIG_ROOT is forbidden:
#   - <target>/test/**         (any .bats or .bash file — helpers + tests)
#   - <target>/lib/**          (any .sh or .bash file)
#   - <target>/lib/**          (extension-less files with a bash/sh shebang)
#
# Excludes '*/fixtures/*' paths: lint-rule fixtures (including this rule's
# own) intentionally contain MCR references as negative cases. Scanning
# them would produce self-flagging meta-recursion. Real tests don't live
# under 'fixtures/' by convention.
discover_test_lib_files() {
  local target="$1"

  # '--exclude fixtures' scopes to path components named 'fixtures', not
  # substring matches. This is important because '$target' itself often
  # lives under a 'fixtures/' path (any lint-rule's own fixtures dir),
  # but we only want to skip 'fixtures/' *inside* the target's test/lib
  # trees — which is exactly the component-match semantic.
  if [[ -d "$target/test" ]]; then
    fd -t f -e bats -e bash -e sh --exclude fixtures . "$target/test"
  fi

  if [[ -d "$target/lib" ]]; then
    fd -t f -e sh -e bash --exclude fixtures . "$target/lib"

    # Extension-less files with a bash/sh shebang under lib/. fd's -e is
    # extension-based, so we filter extension-less separately via -t f
    # with a pattern that matches only names without dots.
    while IFS= read -r f; do
      if head -1 "$f" 2>/dev/null | rg -q '^#!.*\b(bash|sh)\b'; then
        echo "$f"
      fi
    done < <(fd -t f --exclude fixtures '^[^.]+$' "$target/lib")
  fi
}

scan_file() {
  local file="$1"
  local lineno=0
  local line

  while IFS= read -r line || [[ -n "$line" ]]; do
    lineno=$((lineno + 1))

    # Skip full-line comments. We deliberately do NOT attempt to strip
    # inline comments — doing so correctly requires string-literal and
    # escape awareness, and the false-positive cost (a comment like
    # "# $MISE_CONFIG_ROOT was set here" on a line also containing code)
    # is both rare and easy to silence with `# codebase:ignore`.
    [[ "$line" =~ ^[[:space:]]*# ]] && continue

    # Inline opt-out.
    [[ "$line" == *"codebase:ignore"* ]] && continue

    if [[ "$line" =~ $BARE_RE ]] || [[ "$line" =~ $BRACE_RE ]]; then
      local trimmed="${line#"${line%%[![:space:]]*}"}"
      echo "$lineno: $trimmed"
    fi
  done < "$file"
}

failures=0

for target in "${TARGETS[@]}"; do
  if [[ ! -e "$target" ]]; then
    echo "ERROR: target does not exist: $target" >&2
    exit 1
  fi

  name=$(basename "$target")

  # File-level ignore via mise.toml
  toml="$target/mise.toml"
  if [[ -f "$toml" ]] && rg -q 'codebase:ignore mcr-scope' "$toml"; then
    echo "SKIP  $name (codebase:ignore)"
    continue
  fi

  files=()
  while IFS= read -r f; do
    [[ -n "$f" ]] && files+=("$f")
  done < <(discover_test_lib_files "$target")

  if [[ ${#files[@]} -eq 0 ]]; then
    echo "OK    $name (no test/ or lib/ files found)"
    continue
  fi

  hit_count=0
  target_output=""
  for file in "${files[@]}"; do
    rel="${file#"$target"/}"
    while IFS= read -r hit; do
      [[ -z "$hit" ]] && continue
      target_output+="  $rel:$hit"$'\n'
      hit_count=$((hit_count + 1))
    done < <(scan_file "$file")
  done

  if [[ "$hit_count" -gt 0 ]]; then
    echo "FAIL  $name: $hit_count \$MISE_CONFIG_ROOT reference(s) in test/ or lib/"
    printf '%s' "$target_output"
    echo "  hint: test/* → use \$BATS_TEST_DIRNAME; lib/* → use \${BASH_SOURCE[0]}-relative paths"
    echo "        see fold/notes/mise-gotchas.md for the mechanism, or annotate with '# codebase:ignore'"
    failures=$((failures + 1))
  else
    echo "OK    $name (${#files[@]} file(s) clean)"
  fi
done

exit "$failures"
