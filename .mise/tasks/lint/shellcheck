#!/usr/bin/env bash
#MISE description="Run shellcheck against bash task and lib files in a codebase"
#USAGE arg "<targets>…" help="Paths to codebases to check (one or more)"

set -euo pipefail

# Default exclude codes — conventions shared across KKL bash codebases:
#   SC1091 — Not following sourced files (MISE_CONFIG_ROOT resolves at runtime)
#   SC2034 — Unused vars (mise injects usage_* globals the linter can't see)
#   SC2154 — Referenced but not assigned (same — mise provides usage_*)
# Per-repo overrides: add a .shellcheckrc at the repo root, or use inline
# '# shellcheck disable=...' directives.
DEFAULT_EXCLUDES="SC1091,SC2034,SC2154"

IFS=' ' read -ra TARGETS <<< "${usage_targets}"

if [[ ${#TARGETS[@]} -eq 0 ]]; then
  echo "ERROR: at least one target is required" >&2
  exit 1
fi

if ! command -v shellcheck >/dev/null 2>&1; then
  echo "ERROR: shellcheck not found on PATH" >&2
  exit 127  # Unix convention: 127 = command not found
fi

# Discover shell files in a target: .mise/tasks/** (anything with a bash
# shebang or a .sh extension) plus lib/*.sh.
discover_shell_files() {
  local target="$1"

  if [[ -d "$target/.mise/tasks" ]]; then
    find "$target/.mise/tasks" -type f 2>/dev/null | while read -r f; do
      case "$f" in
        *.sh|*.bash) echo "$f" ;;
        *)
          # No extension — check shebang
          if head -1 "$f" 2>/dev/null | grep -qE '^#!.*(bash|sh)\b'; then
            echo "$f"
          fi
          ;;
      esac
    done
  fi

  if [[ -d "$target/lib" ]]; then
    find "$target/lib" -type f \( -name "*.sh" -o -name "*.bash" \) 2>/dev/null
  fi
}

failures=0

for target in "${TARGETS[@]}"; do
  if [[ ! -e "$target" ]]; then
    echo "ERROR: target does not exist: $target" >&2
    exit 1
  fi

  name=$(basename "$target")

  # File-level ignore via mise.toml
  toml="$target/mise.toml"
  if [[ -f "$toml" ]] && head -20 "$toml" | grep -q 'codebase:ignore shellcheck'; then
    echo "SKIP  $name (codebase:ignore)"
    continue
  fi

  # Collect files
  files=()
  while IFS= read -r f; do
    [[ -n "$f" ]] && files+=("$f")
  done < <(discover_shell_files "$target")

  if [[ ${#files[@]} -eq 0 ]]; then
    echo "OK    $name (no shell files found)"
    continue
  fi

  # Pass absolute paths (no cd) — avoids mise re-activating inside the
  # target dir. shellcheck still finds .shellcheckrc by walking up from
  # each file's own directory.
  #
  # --shell=bash is hardcoded: KKL convention is bash-only for .mise/tasks
  # and lib/*.sh files. If POSIX-sh scripts ever land in a target, they'll
  # get spurious bash-ism warnings — revisit by letting shellcheck infer
  # shell from shebang instead.
  if ! violations=$(shellcheck --exclude="$DEFAULT_EXCLUDES" --shell=bash "${files[@]}" 2>&1); then
    count=$(printf '%s\n' "$violations" | grep -cE '^In .* line [0-9]+:' || true)
    echo "FAIL  $name: $count violation(s)"
    printf '%s\n' "$violations" | sed 's/^/  /'
    failures=$((failures + 1))
  else
    echo "OK    $name (${#files[@]} file(s) clean)"
  fi
done

exit "$failures"
